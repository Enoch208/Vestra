# Pinata JWT — pins the agent metadata + logo to IPFS.
# Get one at https://pinata.cloud → API Keys → New Key (Admin or pinning scope).
PINATA_JWT=your_pinata_jwt_here

# Agent wallet private key (0x + 64 hex chars).
# Fund it with Alfajores test CELO for gas: https://faucet.celo.org (choose Alfajores).
AGENT_PRIVATE_KEY=0xyour_wallet_private_key_here
